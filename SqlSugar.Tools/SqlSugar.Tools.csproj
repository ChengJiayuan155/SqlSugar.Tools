<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <RootNamespace>SqlSugar.Tools</RootNamespace>
    <AssemblyName>SqlSugar.Tools</AssemblyName>
    <ApplicationIcon>ico.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Deterministic>true</Deterministic>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <ProjectGuid>{8D1FE3AE-667D-4F01-B0F2-8C699A383AC0}</ProjectGuid>
    <SignAssembly>false</SignAssembly>
    <FileAlignment>512</FileAlignment>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DebugType>full</DebugType>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <DebugType>pdbonly</DebugType>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System.Web" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="EntityFramework" Version="6.5.1" />
    <PackageReference Include="Google.Protobuf" Version="3.34.1" />
    <PackageReference Include="MySql.Data" Version="9.6.0" />
    <PackageReference Include="NetDimension.NanUI" Version="0.6.3239.1" />
    <PackageReference Include="NetDimension.NanUI.Cef3239" Version="3.3239.1723.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="Npgsql" Version="8.0.5" />
    <PackageReference Include="Oracle.ManagedDataAccess" Version="23.26.100" />
    <PackageReference Include="System.Data.SQLite" Version="1.0.119" />
    <PackageReference Include="System.Resources.Extensions" Version="8.0.0" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="wwwroot\**\*" />
  </ItemGroup>
  <ItemGroup>
    <None Include="mysql.json" />
    <None Include="MSSQLtest.json" />
    <None Update="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>
  <ItemGroup>
    <Content Include="ico.ico" />
  </ItemGroup>
  <!-- NanUI 的 targets 只在 AfterBuild 复制到 $(TargetDir)；dotnet publish 默认输出到 publish 子目录时不会带上 CEF 本机文件，导致仅复制/运行 publish 内 exe 时 Bootstrap.Load 失败。 -->
  <Target Name="CopyNanUICefToPublish" AfterTargets="Publish">
    <PropertyGroup>
      <_NuGetPkgRoot Condition="'$(NuGetPackageRoot)' != ''">$(NuGetPackageRoot)</_NuGetPkgRoot>
      <_NuGetPkgRoot Condition="'$(_NuGetPkgRoot)' == ''">$(UserProfile)\.nuget\packages\</_NuGetPkgRoot>
    </PropertyGroup>
    <ItemGroup>
      <_CefPublishFiles Include="$(_NuGetPkgRoot)netdimension.nanui.cef3239\3.3239.1723\NetDimension.NanUI.CEF\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_CefPublishFiles)" DestinationFolder="$(PublishDir)%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Message Importance="high" Text="Copying NanUI CEF runtime to $(PublishDir)..." />
  </Target>
</Project>
